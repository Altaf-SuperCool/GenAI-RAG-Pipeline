# ===== LLM API Keys =====
# Get Groq API key from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# ⚠️ WARNING: OpenAI stores your data for 30 days!
# Get OpenAI API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# ===== Vector Database Configuration =====
# Options: 'faiss' or 'milvus'
# FAISS: Fast, local, file-based (recommended for < 1M vectors)
# Milvus: Enterprise-grade, distributed (recommended for > 1M vectors, production)
VECTOR_DB_TYPE=faiss

# Milvus Connection Settings (only needed if VECTOR_DB_TYPE=milvus)
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION_NAME=devops_knowledgebase
